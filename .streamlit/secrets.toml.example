# Copy this file to secrets.toml and fill in your API keys.
# For Streamlit Cloud: add these in Settings → Secrets.

# Serper.dev — Google Search (https://serper.dev)
SERPER_API_KEY = "YOUR_SERPER_API_KEY_HERE"

# Google Gemini AI (https://aistudio.google.com)
GOOGLE_API_KEY = "YOUR_GOOGLE_API_KEY_HERE"

# Apify — LinkedIn Scraping (https://apify.com)
# COST OPTIMIZATION: Key 1 = paid account, Keys 2-4 = free accounts
# System uses free keys first, paid key as last resort
APIFY_KEY_1 = "YOUR_APIFY_API_KEY_1_HERE"
APIFY_KEY_2 = "YOUR_APIFY_API_KEY_2_HERE"
APIFY_KEY_3 = "YOUR_APIFY_API_KEY_3_HERE"
APIFY_KEY_4 = "YOUR_APIFY_API_KEY_4_HERE"
